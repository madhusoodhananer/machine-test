{
  "info": {
    "name": "Hotel Inventory & Search",
    "description": "API collection for the Hotel Inventory & Search System.\n\nRun the requests in order: Login → Create Hotel → Create Room → Create Booking. Login stores {{token}}; Create Hotel/Room store the returned UUIDs into {{hotel_id}} and {{room_id}} so the later requests chain automatically.\n\nIDs are UUID v4 strings, not integers.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.environment.set('token', json.token);",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}",
                  "pm.test('status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/login", "host": ["{{base_url}}"], "path": ["api", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/logout", "host": ["{{base_url}}"], "path": ["api", "logout"] }
          }
        }
      ]
    },
    {
      "name": "Hotels",
      "item": [
        {
          "name": "Create Hotel",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const id = json.data ? json.data.id : json.id;",
                  "if (id) {",
                  "  pm.environment.set('hotel_id', id);",
                  "  pm.collectionVariables.set('hotel_id', id);",
                  "}",
                  "pm.test('status is 201', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/hotels", "host": ["{{base_url}}"], "path": ["api", "hotels"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Grand Test Hotel\",\n  \"city\": \"Dubai\",\n  \"country\": \"United Arab Emirates\",\n  \"rating\": 5\n}"
            }
          }
        },
        {
          "name": "List Hotels (filtered)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/hotels?city=Dubai&rating=4&per_page=15",
              "host": ["{{base_url}}"],
              "path": ["api", "hotels"],
              "query": [
                { "key": "city", "value": "Dubai" },
                { "key": "rating", "value": "4" },
                { "key": "per_page", "value": "15" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Rooms",
      "item": [
        {
          "name": "Create Room",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const id = json.data ? json.data.id : json.id;",
                  "if (id) {",
                  "  pm.environment.set('room_id', id);",
                  "  pm.collectionVariables.set('room_id', id);",
                  "}",
                  "pm.test('status is 201', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/rooms", "host": ["{{base_url}}"], "path": ["api", "rooms"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hotel_id\": \"{{hotel_id}}\",\n  \"name\": \"Deluxe King\",\n  \"price_per_night\": 120.00,\n  \"max_occupancy\": 2,\n  \"total_rooms\": 5\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Search",
      "item": [
        {
          "name": "Search Availability",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/search?city=Dubai&checkin_date=2026-07-01&checkout_date=2026-07-04&guests=2",
              "host": ["{{base_url}}"],
              "path": ["api", "search"],
              "query": [
                { "key": "city", "value": "Dubai" },
                { "key": "checkin_date", "value": "2026-07-01" },
                { "key": "checkout_date", "value": "2026-07-04" },
                { "key": "guests", "value": "2" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/bookings", "host": ["{{base_url}}"], "path": ["api", "bookings"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"room_id\": \"{{room_id}}\",\n  \"checkin_date\": \"2026-07-01\",\n  \"checkout_date\": \"2026-07-04\",\n  \"guests\": 2\n}"
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "token", "value": "" },
    { "key": "hotel_id", "value": "" },
    { "key": "room_id", "value": "" }
  ]
}
